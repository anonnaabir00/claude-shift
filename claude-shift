#!/usr/bin/env bash
set -euo pipefail

APP_NAME="claude-shift"
VERSION="0.3.1"
BASE_DIR="$HOME/.config/claude-shift"
PROFILES_DIR="$BASE_DIR/profiles"
CURRENT_FILE="$BASE_DIR/current"
CLAUDE_DIR="$HOME/.claude"
CLAUDE_SETTINGS_LOCAL="$CLAUDE_DIR/settings.local.json"

mkdir -p "$PROFILES_DIR" "$CLAUDE_DIR"
chmod 700 "$BASE_DIR" "$PROFILES_DIR" 2>/dev/null || true

# ── Colors ──────────────────────────────────────────────────────
if [[ -t 1 ]]; then
  RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[0;33m'
  CYAN='\033[0;36m'; BOLD='\033[1m'; DIM='\033[2m'; RESET='\033[0m'
else
  RED=''; GREEN=''; YELLOW=''; CYAN=''; BOLD=''; DIM=''; RESET=''
fi

info()  { echo -e "${GREEN}${1}${RESET}"; }
warn()  { echo -e "${YELLOW}${1}${RESET}"; }
err()   { echo -e "${RED}${1}${RESET}" >&2; }
label() { echo -e "${CYAN}${BOLD}${1}${RESET}"; }

# ── Providers ───────────────────────────────────────────────────
# display_name|default_base_url|example_model
PROVIDERS=(
  "Anthropic (direct)|https://api.anthropic.com|claude-sonnet-4-20250514"
  "OpenRouter|https://openrouter.ai/api/v1|anthropic/claude-sonnet-4"
  "Z.AI|https://api.z.ai/api/anthropic|"
  "DeepSeek|https://api.deepseek.com/anthropic|deepseek-chat"
  "Amazon Bedrock|https://bedrock-runtime.us-east-1.amazonaws.com|anthropic.claude-sonnet-4-20250514-v1:0"
  "Google Vertex AI||claude-sonnet-4@20250514"
  "Ollama (local)|http://localhost:11434/v1|llama3.3"
  "LM Studio (local)|http://localhost:1234/v1|"
  "NVIDIA NIM|https://integrate.api.nvidia.com/v1|meta/llama-3.3-70b-instruct"
  "Cloudflare AI Gateway||"
  "Custom (Anthropic-compatible)||"
)

# ── Helpers ─────────────────────────────────────────────────────
list_profiles() {
  ls "$PROFILES_DIR" 2>/dev/null | sed 's/\.env$//' | sort || true
}

current_profile() {
  [[ -f "$CURRENT_FILE" ]] && cat "$CURRENT_FILE" || echo ""
}

profile_exists() {
  [[ -f "$PROFILES_DIR/$1.env" ]]
}

# Read a value with optional default, hidden input for secrets
prompt_value() {
  local lbl="$1" default="${2:-}" secret="${3:-false}"
  local prompt_text="  ${lbl}"
  [[ -n "$default" ]] && prompt_text+=" [${default}]"
  prompt_text+=": "

  if [[ "$secret" == "true" ]]; then
    echo -n "$prompt_text" >/dev/tty
    read -rs val </dev/tty
    echo >/dev/tty
  else
    read -rp "$prompt_text" val </dev/tty
  fi
  echo "${val:-$default}"
}

# Number-based menu selector (works in all terminals)
select_menu() {
  local title="$1"; shift
  local options=("$@")
  local count=${#options[@]}

  echo "" >/dev/tty
  echo -e "  ${BOLD}${title}:${RESET}" >/dev/tty
  for i in "${!options[@]}"; do
    local num=$((i + 1))
    echo -e "  ${GREEN}${num})${RESET} ${options[$i]}" >/dev/tty
  done
  echo "" >/dev/tty

  local choice
  while true; do
    echo -n "  Choose [1-${count}]: " >/dev/tty
    read -r choice </dev/tty
    if [[ "$choice" == "q" ]]; then
      echo "-1"
      return
    fi
    if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= count )); then
      echo $((choice - 1))
      return
    fi
    echo "  Invalid choice." >/dev/tty
  done
}

# ── Write settings.local.json ──────────────────────────────────
write_settings() {
  local profile="$1"
  local env_file="$PROFILES_DIR/$profile.env"
  [[ ! -f "$env_file" ]] && { err "Profile '$profile' not found."; return 1; }

  # Clear vars before sourcing
  unset ANTHROPIC_API_KEY ANTHROPIC_BASE_URL ANTHROPIC_AUTH_TOKEN ZAI_API_KEY CLAUDE_MODEL_OVERRIDE 2>/dev/null || true

  # Source profile vars
  set -a; source "$env_file"; set +a

  # Build env block
  local env_json="{"
  local first=true
  for var in ANTHROPIC_API_KEY ANTHROPIC_BASE_URL ANTHROPIC_AUTH_TOKEN ZAI_API_KEY; do
    local val="${!var:-}"
    if [[ -n "$val" ]]; then
      [[ "$first" == "true" ]] && first=false || env_json+=","
      env_json+=$'\n'"      \"$var\": \"$val\""
    fi
  done
  env_json+=$'\n'"    }"

  # Build model override
  local model_line=""
  if [[ -n "${CLAUDE_MODEL_OVERRIDE:-}" ]]; then
    model_line=","$'\n'"  \"model\": \"$CLAUDE_MODEL_OVERRIDE\""
  fi

  # Check for caveman plugin + auto-enable
  local caveman_line=""
  if [[ -d "$HOME/.claude/plugins/cache/caveman" ]] || command -v caveman >/dev/null 2>&1; then
    caveman_line=","$'\n'"  \"preferences\": {"$'\n'"    \"caveman\": {"$'\n'"      \"enabled\": true,"$'\n'"      \"level\": \"ultra\","$'\n'"      \"recommended\": true"$'\n'"    }"$'\n'"  }"
  fi

  cat > "$CLAUDE_SETTINGS_LOCAL" <<EOF
{
  "\$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": ${env_json}${model_line}${caveman_line}
}
EOF

  chmod 600 "$CLAUDE_SETTINGS_LOCAL"
  echo "$profile" > "$CURRENT_FILE"
  info "Switched to profile: $profile"
}

# ── CMD: add ────────────────────────────────────────────────────
cmd_add() {
  echo
  label "Add new provider profile"

  # Pick provider
  local names=()
  for p in "${PROVIDERS[@]}"; do
    names+=("${p%%|*}")
  done
  local idx
  idx=$(select_menu "Select provider" "${names[@]}")
  [[ "$idx" == "-1" ]] && return

  local provider="${PROVIDERS[$idx]}"
  IFS='|' read -r pname default_url example_model <<< "$provider"

  echo
  info "Provider: $pname"
  echo

  # Auto-suggest profile name based on provider
  local slug
  slug=$(echo "$pname" | tr '[:upper:]' '[:lower:]' | sed 's/ (.*//;s/[^a-z0-9]/-/g;s/--*/-/g;s/-$//')
  # If slug already exists, append a number
  local suggested="$slug"
  if profile_exists "$suggested"; then
    local n=2
    while profile_exists "${slug}-${n}"; do ((n++)); done
    suggested="${slug}-${n}"
  fi

  local profile_name
  profile_name=$(prompt_value "Profile name" "$suggested")
  profile_name="${profile_name// /-}"
  [[ -z "$profile_name" ]] && { err "Name required."; return 1; }

  if profile_exists "$profile_name"; then
    warn "Profile '$profile_name' already exists. Updating."
  fi

  local env_file="$PROFILES_DIR/$profile_name.env"

  # Anthropic (direct) = OAuth login, no manual key needed
  if [[ "$pname" == "Anthropic (direct)" ]]; then
    # Model override only
    local model
    model=$(prompt_value "Model override" "$example_model")

    # Write clean .env — no API key, uses Claude's built-in OAuth
    cat > "$env_file" <<EOF
# Uses Claude's built-in OAuth login (browser-based)
ANTHROPIC_BASE_URL=https://api.anthropic.com
CLAUDE_MODEL_OVERRIDE=${model}
EOF
    chmod 600 "$env_file"
    info "Profile '$profile_name' saved."
    echo
    info "This profile uses Claude's built-in OAuth login."
    info "Run 'claude' after switching — it will open browser to authenticate."

    echo
    read -rp "  Switch to this profile now? (Y/n): " yn </dev/tty
    [[ ! "$yn" =~ ^[Nn]$ ]] && write_settings "$profile_name"
    return
  fi

  # All other providers need API key / auth token
  local key_label="API Key"
  [[ "$pname" == "Z.AI" ]] && key_label="Auth Token"
  local api_key
  api_key=$(prompt_value "$key_label" "" "true")
  [[ -z "$api_key" ]] && { err "${key_label} required."; return 1; }

  # Base URL
  local base_url
  base_url=$(prompt_value "Base URL" "$default_url")

  # Model override
  local model
  model=$(prompt_value "Model override" "$example_model")

  # Auth token (optional, for custom)
  local auth_token=""
  if [[ "$pname" == "Custom (Anthropic-compatible)" ]]; then
    auth_token=$(prompt_value "Auth token (optional)" "" "true")
  fi

  # Write .env file
  cat > "$env_file" <<EOF
ANTHROPIC_BASE_URL=${base_url}
CLAUDE_MODEL_OVERRIDE=${model}
EOF

  if [[ "$pname" == "Z.AI" ]]; then
    echo "ANTHROPIC_AUTH_TOKEN=${api_key}" >> "$env_file"
  else
    echo "ANTHROPIC_API_KEY=${api_key}" >> "$env_file"
  fi

  [[ -n "$auth_token" ]] && echo "ANTHROPIC_AUTH_TOKEN=${auth_token}" >> "$env_file"

  chmod 600 "$env_file"
  info "Profile '$profile_name' saved."

  echo
  read -rp "  Switch to this profile now? (Y/n): " yn </dev/tty
  [[ ! "$yn" =~ ^[Nn]$ ]] && write_settings "$profile_name"
}

# ── CMD: switch ─────────────────────────────────────────────────
cmd_switch() {
  local target="${1:-}"

  # Direct switch if name provided
  if [[ -n "$target" ]]; then
    if profile_exists "$target"; then
      write_settings "$target"
    else
      err "Profile '$target' not found."
      echo "  Available: $(list_profiles | tr '\n' ', ')"
      return 1
    fi
    return
  fi

  # Interactive
  local profiles=()
  while IFS= read -r line; do profiles+=("$line"); done < <(list_profiles)
  [[ ${#profiles[@]} -eq 0 ]] && { warn "No profiles. Run: claude-shift add"; return; }

  local cur
  cur=$(current_profile)

  local display=()
  for p in "${profiles[@]}"; do
    if [[ "$p" == "$cur" ]]; then
      display+=("$p (current)")
    else
      display+=("$p")
    fi
  done

  local idx
  idx=$(select_menu "Switch profile" "${display[@]}")
  [[ "$idx" == "-1" ]] && return

  write_settings "${profiles[$idx]}"
}

# ── CMD: list ───────────────────────────────────────────────────
cmd_list() {
  local cur
  cur=$(current_profile)
  local profiles=()
  while IFS= read -r line; do profiles+=("$line"); done < <(list_profiles)

  if [[ ${#profiles[@]} -eq 0 ]]; then
    warn "No profiles. Run: claude-shift add"
    return
  fi

  echo
  label "Profiles:"
  for p in "${profiles[@]}"; do
    if [[ "$p" == "$cur" ]]; then
      echo -e "  ${GREEN}* ${p}${RESET}"
    else
      echo -e "    ${p}"
    fi
  done
  echo
}

# ── CMD: current ────────────────────────────────────────────────
cmd_current() {
  local cur
  cur=$(current_profile)
  if [[ -n "$cur" ]]; then
    info "Current: $cur"
  else
    warn "No profile active."
  fi
}

# ── CMD: remove ─────────────────────────────────────────────────
cmd_remove() {
  local target="${1:-}"
  if [[ -z "$target" ]]; then
    local profiles=()
    while IFS= read -r line; do profiles+=("$line"); done < <(list_profiles)
    [[ ${#profiles[@]} -eq 0 ]] && { warn "No profiles."; return; }

    local idx
    idx=$(select_menu "Remove profile" "${profiles[@]}")
    [[ "$idx" == "-1" ]] && return
    target="${profiles[$idx]}"
  fi

  if ! profile_exists "$target"; then
    err "Profile '$target' not found."
    return 1
  fi

  read -rp "  Remove profile '$target'? (y/N): " yn </dev/tty
  if [[ "$yn" =~ ^[Yy]$ ]]; then
    rm -f "$PROFILES_DIR/$target.env"
    local cur
    cur=$(current_profile)
    [[ "$cur" == "$target" ]] && rm -f "$CURRENT_FILE"
    info "Removed: $target"
  fi
}

# ── CMD: edit ───────────────────────────────────────────────────
cmd_edit() {
  local target="${1:-}"
  if [[ -z "$target" ]]; then
    local profiles=()
    while IFS= read -r line; do profiles+=("$line"); done < <(list_profiles)
    [[ ${#profiles[@]} -eq 0 ]] && { warn "No profiles."; return; }

    local idx
    idx=$(select_menu "Edit profile" "${profiles[@]}")
    [[ "$idx" == "-1" ]] && return
    target="${profiles[$idx]}"
  fi

  if ! profile_exists "$target"; then
    err "Profile '$target' not found."
    return 1
  fi

  local env_file="$PROFILES_DIR/$target.env"
  local editor="${EDITOR:-nano}"
  $editor "$env_file"
  info "Profile '$target' updated."

  local cur
  cur=$(current_profile)
  if [[ "$cur" == "$target" ]]; then
    read -rp "  Re-apply this profile? (Y/n): " yn </dev/tty
    [[ ! "$yn" =~ ^[Nn]$ ]] && write_settings "$target"
  fi
}

# ── Usage ───────────────────────────────────────────────────────
usage() {
  echo -e "${BOLD}claude-shift${RESET} v${VERSION} - Profile switcher for Claude Code
${BOLD}USAGE:${RESET}
  claude-shift <command> [args]

${BOLD}COMMANDS:${RESET}
  add                 Add new provider profile (interactive TUI)
  switch [name]       Switch profile (interactive if no name given)
  list                List all profiles
  current             Show active profile
  edit [name]         Edit a profile
  remove [name]       Remove a profile
  version             Show version

${BOLD}EXAMPLES:${RESET}
  claude-shift add                  # Interactive provider setup
  claude-shift switch work          # Direct switch to 'work' profile
  claude-shift switch               # Interactive profile picker
  claude-shift list                 # Show all profiles

${BOLD}SUPPORTED PROVIDERS:${RESET}
  Anthropic, OpenRouter, Z.AI, DeepSeek, Bedrock,
  Vertex AI, Ollama, LM Studio, NVIDIA NIM, Cloudflare, Custom

${BOLD}FILES:${RESET}
  Profiles:  ~/.config/claude-shift/profiles/
  Settings:  ~/.claude/settings.local.json"
}

# ── Main dispatch ───────────────────────────────────────────────
main() {
  local cmd="${1:-}"
  shift 2>/dev/null || true

  case "$cmd" in
    add|a)       cmd_add "$@" ;;
    switch|sw|s) cmd_switch "$@" ;;
    list|ls|l)   cmd_list "$@" ;;
    current|c)   cmd_current "$@" ;;
    edit|e)      cmd_edit "$@" ;;
    remove|rm)   cmd_remove "$@" ;;
    version|v|-v|--version) echo "$APP_NAME v$VERSION" ;;
    help|-h|--help) usage ;;
    "")          usage ;;
    *)           err "Unknown command: $cmd"; echo; usage; exit 1 ;;
  esac
}

main "$@"
